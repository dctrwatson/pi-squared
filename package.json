{
  "name": "pi-squared",
  "version": "0.0.1",
  "description": "Pi extensions and skills",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-skill"
  ],
  "author": "dctrwatson",
  "license": "Unlicense",
  "repository": {
    "type": "git",
    "url": "git@github.com:dctrwatson/pi-squared.git"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "check": "node ./node_modules/typescript/bin/tsc --noEmit && node ./node_modules/typescript/bin/tsc --noEmit -p manual-extensions/slack-pi/tsconfig.json",
    "clean": "echo 'nothing to clean'",
    "build": "echo 'nothing to build'",
    "check:slack-pi": "node ./node_modules/typescript/bin/tsc --noEmit -p manual-extensions/slack-pi/tsconfig.json"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "^0.65.0",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*",
    "typescript": "^5.7.2"
  }
}
