{
  "manifest_version": 3,
  "name": "Pi Slack (Scaffold)",
  "version": "0.0.1",
  "description": "Scaffold for the local Pi Slack Chrome bridge.",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "https://app.slack.com/*",
    "https://*.slack.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.slack.com/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Pi Slack",
    "default_popup": "popup.html"
  }
}
